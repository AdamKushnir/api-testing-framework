            {
              "name": "GET Character Invalid ID",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "// =====================================================",
                      "// 📁 GET Character Invalid ID — negative test",
                      "// =====================================================",
                      "//",
                      "// Verifies API contract for non-existent resources.",
                      "// A well-behaved API must return 404 with a structured error body —",
                      "// not a 200 with empty data, not a 500, not an unstructured string.",
                      "",
                      "// Overrides folder default \"200\" — failure to return 404 is itself a test failure.",
                      "pm.variables.set(\"expectedStatus\", \"404\");",
                      "",
                      "// Error response contract: { \"error\": \"Character not found\" }",
                      "// Only the presence of the \"error\" key is asserted — value is not constrained.",
                      "pm.variables.set(\"requiredKeys\", JSON.stringify([\"error\"]));",
                      "",
                      "// Character fields (id, name, status...) are absent in error responses —",
                      "// asserting them here would always fail. Empty arrays skip those checks entirely.",
                      "pm.variables.set(\"nonEmptyStringFields\", JSON.stringify([]));",
                      "pm.variables.set(\"positiveNumberFields\", JSON.stringify([]));",
                      "pm.variables.set(\"urlFields\",            JSON.stringify([]));",
                      "pm.variables.set(\"dateTimeFields\",       JSON.stringify([]));",
                      "pm.variables.set(\"enumRules\",            JSON.stringify({}));"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{rickAndMortyBaseUrl}}character/{{errorcharacterId}}",
                  "host": [
                    "{{rickAndMortyBaseUrl}}character"
                  ],
                  "path": [
                    "{{errorcharacterId}}"
                  ]
                }
