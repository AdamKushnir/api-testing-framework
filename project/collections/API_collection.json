      ],
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "requests": {},
            "exec": [
              "// =====================================================",
              "// 📁 FOLDER DEFAULTS — tests (parent wrapper)",
              "// =====================================================",
              "//",
              "// Top-level defaults inherited by every request in this collection.",
              "// Subfolder and request pre-request scripts override individual values",
              "// as needed — only the delta needs to be specified, not the full config.",
              "//",
              "// Override priority (lowest → highest):",
              "//   This script → Subfolder pre-req → Request pre-req",
              "",
              "// All GET endpoints in this collection are expected to respond successfully.",
              "pm.variables.set(\"expectedStatus\",      \"200\");",
              "",
              "// 1000ms is a conservative baseline — latency-sensitive subfolders",
              "// (e.g. RickAndMorty) tighten this to 150ms in their own pre-req.",
              "pm.variables.set(\"maxResponseTime\",     \"150\");",
              "",
              "// All endpoints return JSON — no exceptions in current scope.",
              "pm.variables.set(\"expectedContentType\", \"application/json\");",
              "",
              "// REST Countries returns a root-level array [ {...}, {...} ].",
              "// RickAndMorty subfolder overrides this to \"object\" (paginated wrapper).",
              "pm.variables.set(\"expectedRootType\",    \"array\");"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              "// =====================================================\r",
              "// 1. CORE HELPERS\r",
              "// =====================================================\r",
              "//\r",
              "// Clean utility functions independent of the test context.\r",
              "// Injected into every request cycle — no global state.\r",
              "\r",
              "// __CORE_INJECT_START__\r",
              "\r",
              "/**\r",
              " * Asserts HTTP response status code matches expected value.\r",
              " *\r",
              " * @param {Object} response - pm.response object\r",
              " * @param {number} expected - Expected HTTP status code (e.g. 200, 404)\r",
              " */\r",
              "function checkStatus(response, expected) {\r",
              "  pm.expect(response.code).to.eql(expected);\r",
              "}\r",
              "\r",
              "/**\r",
              " * Asserts response time is within acceptable threshold.\r",
              " * Catches performance regressions before they reach production.\r",
              " *\r",
              " * @param {Object} response - pm.response object\r",
              " * @param {number} max      - Maximum allowed response time in ms\r",
              " */\r",
              "function checkResponseTime(response, max) {\r",
              "  pm.expect(response.responseTime).to.be.below(max);\r",
              "}\r",
              "\r",
              "/**\r",
              " * Parses response body as JSON.\r",
              " * Centralised so parse failures surface in one place, not scattered across tests.\r",
              " *\r",
              " * @param {Object} response - pm.response object\r",
              " * @returns {Object|Array}\r",
              " */\r",
              "function parseBody(response) {\r",
              "  return response.json();\r",
              "}\r",
              "\r",
              "/**\r",
              " * Validates response body against a JSON Schema (Draft 07 via Ajv).\r",
              " *\r",
              " * @param {Object} schema - Valid JSON Schema object\r",
              " */\r",
              "function validateSchema(schema) {\r",
              "  pm.response.to.have.jsonSchema(schema);\r",
              "}\r",
              "\r",
              "/**\r",
              " * Resolves a nested value using dot notation path.\r",
              " *\r",
              " * Examples:\r",
              " *   getByPath({ user: { name: \"Jan\" } }, \"user.name\")   → \"Jan\"\r",
              " *   getByPath({ results: [{ id: 5 }] }, \"results.0.id\") → 5\r",
              " *   getByPath(obj, \"\")                                   → obj\r",
              " *\r",
              " * Uses reduce() to traverse arbitrary depth without recursion.\r",
              " * The acc != null guard prevents TypeError on undefined intermediate values.\r",
              " *\r",
              " * @param {Object} obj  - Source object\r",
              " * @param {string} path - Dot-separated path string\r",
              " * @returns {*}         - Resolved value or undefined if path does not exist\r",
              " */\r",
              "function getByPath(obj, path) {\r",
              "  if (!path) return obj;\r",
              "\r",
              "  return path.split('.').reduce(\r",
              "    (acc, key) => (acc != null ? acc[key] : undefined),\r",
              "    obj\r",
              "  );\r",
              "}\r",
              "\r",
              "/**\r",
              " * Safely reads and parses a JSON-encoded Postman variable.\r",
              " * Postman stores all variables as strings — arrays and objects must be\r",
              " * serialised on write and deserialised on read.\r",
              " * Behaviour:\r",
              " *   - Missing or empty variable → returns fallback (silent, expected)\r",
              " *   - Invalid JSON              → fails with explicit test message (loud, unexpected)\r",
              " \r",
              " * @param {string} key - Variable name\r",
              " * @param {*}      fallback - Default value when variable is absent ([] or {})\r",
              " * @returns {*}\r",
              " */\r",
              "function readJsonVariable(key, fallback) {\r",
              "  const raw = pm.variables.get(key);\r",
              "\r",
              "  if (!raw) return fallback;\r",
              "\r",
              "  try {\r",
              "    return JSON.parse(raw);\r",
              "  } catch (e) {\r",
              "    pm.test(`Invalid JSON config: ${key}`, () => {\r",
              "      throw new Error(`Variable ${key} must be valid JSON`);\r",
              "    });\r",
              "\r",
              "    return fallback;\r",
              "  }\r",
              "}\r",
              "\r",
              "// __CORE_INJECT_END__\r",
              "\r",
              "\r",
              "// =====================================================\r",
              "//  2. CONFIGURATION\r",
              "// =====================================================\r",
              "//\r",
              "// All test configuration is read from Postman variables.\r",
              "// Variable resolution follows this priority chain (lowest → highest):\r",
              "//\r",
              "//   Collection Variables  →  Folder Pre-request  →  Request Pre-request\r",
              "//\r",
              "// This allows a single shared test script to serve every endpoint —\r",
              "// behaviour is controlled entirely by variable values, not by code changes.\r",
              "// Adding a new endpoint = set variables, write no new test logic.\r",
              "//\r",
              "// Convention:\r",
              "//   Scalar values (string, number) → pm.variables.get()\r",
              "//   Composite values (array, object) → readJsonVariable()\r",
              "\r",
              "const expectedStatus      = pm.variables.get(\"expectedStatus\");\r",
              "const maxResponseTime     = pm.variables.get(\"maxResponseTime\");\r",
              "const expectedContentType = pm.variables.get(\"expectedContentType\");\r",
              "const expectedRootType    = pm.variables.get(\"expectedRootType\");\r",
              "\r",
              "// JSON-encoded validation rules — fallbacks prevent forEach/Object.keys\r",
              "// from throwing TypeError when a variable is absent or empty.\r",
              "const requiredKeys         = readJsonVariable(\"requiredKeys\", []);\r",
              "const enumRules            = readJsonVariable(\"enumRules\", {});\r",
              "const nonEmptyStringFields = readJsonVariable(\"nonEmptyStringFields\", []);\r",
              "const positiveNumberFields = readJsonVariable(\"positiveNumberFields\", []);\r",
              "const booleanFields        = readJsonVariable(\"booleanFields\", []);\r",
              "const urlFields            = readJsonVariable(\"urlFields\", []);\r",
              "const dateTimeFields       = readJsonVariable(\"dateTimeFields\", []);\r",
              "\r",
              "// Schema store — single variable holding all JSON Schemas as a keyed object:\r",
              "// { \"user.schema\": {...}, \"error.schema\": {...} }\r",
              "// Individual requests reference a schema by key, not by storing the full object.\r",
              "const schemaStore     = readJsonVariable(\"schema_store\", {});\r",
              "const schemaSingleKey = pm.variables.get(\"schemaSingleKey\");\r",
              "const schemaListKey   = pm.variables.get(\"schemaListKey\");\r",
              "const schemaErrorKey  = pm.variables.get(\"schemaErrorKey\");\r",
              "\r",
              "/**\r",
              " * Resolves a JSON Schema from schema_store (preferred) or a legacy standalone variable.\r",
              "\r",
              " * Two-source fallback exists for backward compatibility — older collection setups\r",
              " * stored each schema in a dedicated variable rather than in a central store.\r",
              " \r",
              " * Failure modes:\r",
              " *   - Key provided but missing from store → explicit failing test (misconfiguration)\r",
              " *   - No key and no legacy variable       → returns null (schema validation skipped)\r",
              " \r",
              " * @param {string|null} schemaKey         - Key to look up in schema_store\r",
              " * @param {string}      legacyVariableKey - Fallback variable name (legacy support)\r",
              " * @returns {Object|null}\r",
              " */\r",
              "function resolveSchema(schemaKey, legacyVariableKey) {\r",
              "  if (schemaKey) {\r",
              "    if (schemaStore && schemaStore[schemaKey]) return schemaStore[schemaKey];\r",
              "\r",
              "    pm.test(`Schema key exists in schema_store: ${schemaKey}`, () => {\r",
              "      throw new Error(`Schema key '${schemaKey}' not found in schema_store`);\r",
              "    });\r",
              "    return null;\r",
              "  }\r",
              "\r",
              "  const raw = pm.variables.get(legacyVariableKey);\r",
              "  if (!raw) return null;\r",
              "\r",
              "  try {\r",
              "    return JSON.parse(raw);\r",
              "  } catch (e) {\r",
              "    pm.test(`Invalid schema JSON in variable: ${legacyVariableKey}`, () => {\r",
              "      throw new Error(`Variable ${legacyVariableKey} must contain valid JSON schema`);\r",
              "    });\r",
              "    return null;\r",
              "  }\r",
              "}\r",
              "\r",
              "const schemaSingle = resolveSchema(schemaSingleKey, \"schema_single\");\r",
              "const schemaList   = resolveSchema(schemaListKey,   \"schema_list\");\r",
              "const schemaError  = resolveSchema(schemaErrorKey,  \"schema_error\");\r",
              "\r",
              "// Resets a variable to its empty sentinel value.\r",
              "// Named clearValue rather than setValue to make the intent explicit at call sites.\r",
              "const clearValue = (key, empty) => pm.variables.set(key, empty);\r",
              "\r",
              "\r",
              "// =====================================================\r",
              "//  3. CONFIG VALIDATION\r",
              "// =====================================================\r",
              "//\r",
              "// Fail-fast guard — validates required variables before any test logic runs.\r",
              "//\r",
              "// Without this, missing config produces cryptic runtime errors deep in the script\r",
              "// (\"Cannot convert undefined to number\") with no indication of root cause.\r",
              "// With this, the failure is immediate and points directly at the missing variable.\r",
              "\r",
              "const REQUIRED_CONFIG = [\"expectedStatus\", \"maxResponseTime\", \"expectedContentType\"];\r",
              "let configValid = true;\r",
              "\r",
              "REQUIRED_CONFIG.forEach((key) => {\r",
              "  const val = pm.variables.get(key);\r",
              "  pm.test(`[Config] '${key}' is set and non-empty`, () => {\r",
              "    if (!val || String(val).trim() === \"\") {\r",
              "      configValid = false;\r",
              "      throw new Error(`Required config variable '${key}' is missing or empty. Set it in the folder pre-request script.`);\r",
              "    }\r",
              "  });\r",
              "});\r",
              "\r",
              "// expectedStatus must be a valid HTTP status code integer (100–599).\r",
              "pm.test(\"[Config] 'expectedStatus' is a valid HTTP status code\", () => {\r",
              "  const val = Number(pm.variables.get(\"expectedStatus\"));\r",
              "  if (isNaN(val) || val < 100 || val > 599) {\r",
              "    configValid = false;\r",
              "    throw new Error(`'expectedStatus' must be a valid HTTP status code (100–599), got: '${pm.variables.get(\"expectedStatus\")}'`);\r",
              "  }\r",
              "});\r",
              "\r",
              "// maxResponseTime must be a positive integer — zero or negative has no meaningful interpretation.\r",
              "pm.test(\"[Config] 'maxResponseTime' is a positive number\", () => {\r",
              "  const val = Number(pm.variables.get(\"maxResponseTime\"));\r",
              "  if (isNaN(val) || val <= 0) {\r",
              "    configValid = false;\r",
              "    throw new Error(`'maxResponseTime' must be a positive number, got: '${pm.variables.get(\"maxResponseTime\")}'`);\r",
              "  }\r",
              "});\r",
              "\r",
              "// Abort early — sections 4–8 are skipped when config is invalid.\r",
              "// Cleanup runs here because section 8 will never be reached.\r",
              "if (!configValid) {\r",
              "  console.error(\"[Contract] Config validation failed — skipping all further checks.\");\r",
              "  clearValue(\"expectedRootType\", \"\");\r",
              "  clearValue(\"requiredKeys\", \"[]\");\r",
              "  clearValue(\"enumRules\", \"{}\");\r",
              "  clearValue(\"nonEmptyStringFields\", \"[]\");\r",
              "  clearValue(\"positiveNumberFields\", \"[]\");\r",
              "  clearValue(\"booleanFields\", \"[]\");\r",
              "  clearValue(\"urlFields\", \"[]\");\r",
              "  clearValue(\"dateTimeFields\", \"[]\");\r",
              "  return;\r",
              "}\r",
              "\r",
              "\r",
              "// =====================================================\r",
              "//  4. RESPONSE PARSING\r",
              "// =====================================================\r",
              "//\r",
              "// Body is parsed once and shared across all subsequent assertions.\r",
              "// Repeated calls to parseBody() would be wasteful and risk inconsistency\r",
              "// if the response object were ever mutated between calls.\r",
              "\r",
              "const jsonData = parseBody(pm.response);\r",
              "\r",
              "\r",
              "// =====================================================\r",
              "//  5. BASELINE ASSERTIONS\r",
              "// =====================================================\r",
              "//\r",
              "// Three checks that every well-behaved endpoint must satisfy:\r",
              "//   1. Correct HTTP status code\r",
              "//   2. Acceptable response time\r",
              "//   3. Correct Content-Type header\r",
              "//\r",
              "// Each assertion is gated on its variable being set — omitting the variable\r",
              "// skips that assertion without modifying this script.\r",
              "// Example use case: binary responses where Content-Type checking is irrelevant.\r",
              "\r",
              "if (expectedStatus) {\r",
              "  // pm.variables.get() always returns a string — Number() cast is required.\r",
              "  pm.test(`Status ${expectedStatus}`, () => {\r",
              "    checkStatus(pm.response, Number(expectedStatus));\r",
              "  });\r",
              "}\r",
              "\r",
              "if (maxResponseTime) {\r",
              "  pm.test(`Response time < ${maxResponseTime}ms`, () => {\r",
              "    checkResponseTime(pm.response, Number(maxResponseTime));\r",
              "  });\r",
              "}\r",
              "\r",
              "if (expectedContentType) {\r",
              "  // .include() rather than .eql() — Content-Type often carries charset suffix:\r",
              "  // \"application/json; charset=utf-8\". We match the type, not the full header value.\r",
              "  pm.test(`Content-Type includes ${expectedContentType}`, () => {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\") || \"\")\r",
              "      .to.include(expectedContentType);\r",
              "  });\r",
              "}\r",
              "\r",
              "\r",
              "// =====================================================\r",
              "//  6. SCHEMA VALIDATION\r",
              "// =====================================================\r",
              "//\r",
              "// Structural validation — verifies shape and field types against JSON Schema.\r",
              "// Complements section 7 (value validation) rather than replacing it.\r",
              "//\r",
              "// REST APIs typically return one of three response shapes:\r",
              "//\r",
              "//   A — Array root:   [ {id:1}, {id:2} ]\r",
              "//       schemaList describes one item.\r",
              "//\r",
              "//   B — Single object: { \"id\": 1, \"name\": \"...\" }\r",
              "//       schemaSingle describes the object.\r",
              "//\r",
              "//   C — Paginated:    { \"results\": [...], \"count\": 42 }\r",
              "//       Django REST Framework convention — schemaList describes one result item.\r",
              "//\r",
              "// 4xx/5xx responses are validated against schemaError (different shape from success).\r",
              "\r",
              "if (pm.response.code >= 200 && pm.response.code < 300) {\r",
              "\r",
              "  // Shape A — array at root\r",
              "  if (Array.isArray(jsonData) && schemaList) {\r",
              "    pm.test(\"Schema valid - ARRAY ROOT LIST\", () => {\r",
              "      validateSchema({ type: \"array\", items: schemaList });\r",
              "    });\r",
              "  }\r",
              "\r",
              "  // Shape B — single object (no results key, not an array)\r",
              "  if (jsonData && !Array.isArray(jsonData) && !jsonData.results && schemaSingle) {\r",
              "    pm.test(\"Schema valid - SINGLE OBJECT\", () => {\r",
              "      validateSchema(schemaSingle);\r",
              "    });\r",
              "  }\r",
              "\r",
              "  // Shape C — paginated wrapper with results array\r",
              "  // Wrapper keys (count, next, previous) are intentionally not enforced here —\r",
              "  // they vary across endpoints and are validated per-request via requiredKeys.\r",
              "  if (jsonData && jsonData.results && schemaList) {\r",
              "    pm.test(\"Schema valid - LIST\", () => {\r",
              "      validateSchema({\r",
              "        type: \"object\",\r",
              "        properties: {\r",
              "          results: { type: \"array\", items: schemaList }\r",
              "        }\r",
              "      });\r",
              "    });\r",
              "  }\r",
              "}\r",
              "\r",
              "// >= 400 intentionally covers 5xx as well — server errors also have a defined error schema.\r",
              "if (pm.response.code >= 400 && schemaError) {\r",
              "  pm.test(\"Schema valid - ERROR\", () => {\r",
              "    validateSchema(schemaError);\r",
              "  });\r",
              "}\r",
              "\r",
              "\r",
              "// =====================================================\r",
              "//  7. DATA VALIDATION\r",
              "// =====================================================\r",
              "//\r",
              "// Value-level assertions — enforces business rules on response content.\r",
              "// Schema validation (section 6) checks structure; this section checks values.\r",
              "//\r",
              "// All rules are driven by variables set in pre-request scripts.\r",
              "// Adding a field to validate = update the variable, change no test code.\r",
              "\r",
              "// Root type check — typeof [] === \"object\" in JS, hence the Array.isArray branch.\r",
              "if (expectedRootType) {\r",
              "  pm.test(`Root type is ${expectedRootType}`, () => {\r",
              "    const actualType = Array.isArray(jsonData) ? \"array\" : typeof jsonData;\r",
              "    pm.expect(actualType).to.eql(expectedRootType);\r",
              "  });\r",
              "}\r",
              "\r",
              "// Key existence — dot notation paths, tests presence only (not value).\r",
              "requiredKeys.forEach((key) => {\r",
              "  pm.test(`Required key exists: ${key}`, () => {\r",
              "    pm.expect(getByPath(jsonData, key)).to.not.equal(undefined);\r",
              "  });\r",
              "});\r",
              "\r",
              "// Enum — field value must be one of the allowed set.\r",
              "// Format: { \"status\": [\"Alive\", \"Dead\", \"unknown\"] }\r",
              "Object.keys(enumRules).forEach((field) => {\r",
              "  pm.test(`Enum valid: ${field}`, () => {\r",
              "    pm.expect(enumRules[field]).to.include(getByPath(jsonData, field));\r",
              "  });\r",
              "});\r",
              "\r",
              "// Non-empty strings — .trim() rejects whitespace-only values.\r",
              "nonEmptyStringFields.forEach((field) => {\r",
              "  pm.test(`String not empty: ${field}`, () => {\r",
              "    const value = getByPath(jsonData, field);\r",
              "    pm.expect(value).to.be.a(\"string\");\r",
              "    pm.expect(value.trim().length).to.be.above(0);\r",
              "  });\r",
              "});\r",
              "\r",
              "// Positive numbers — .above(0) explicitly excludes zero.\r",
              "positiveNumberFields.forEach((field) => {\r",
              "  pm.test(`Positive number: ${field}`, () => {\r",
              "    const value = getByPath(jsonData, field);\r",
              "    pm.expect(value).to.be.a(\"number\");\r",
              "    pm.expect(value).to.be.above(0);\r",
              "  });\r",
              "});\r",
              "\r",
              "// Booleans — typeof check catches string \"true\"/\"false\" masquerading as booleans.\r",
              "booleanFields.forEach((field) => {\r",
              "  pm.test(`Boolean field: ${field}`, () => {\r",
              "    pm.expect(typeof getByPath(jsonData, field)).to.eql(\"boolean\");\r",
              "  });\r",
              "});\r",
              "\r",
              "// URLs — protocol check only; full RFC validation would be excessive for API tests.\r",
              "urlFields.forEach((field) => {\r",
              "  pm.test(`Valid URL: ${field}`, () => {\r",
              "    const value = getByPath(jsonData, field);\r",
              "    pm.expect(value).to.be.a(\"string\");\r",
              "    pm.expect(/^https?:\\/\\//.test(value)).to.eql(true);\r",
              "  });\r",
              "});\r",
              "\r",
              "// Datetime strings — Date.parse() accepts ISO 8601, RFC 2822 and other JS-parseable formats.\r",
              "// Returns NaN for invalid input — isNaN check confirms successful parse.\r",
              "dateTimeFields.forEach((field) => {\r",
              "  pm.test(`Valid datetime: ${field}`, () => {\r",
              "    const value = getByPath(jsonData, field);\r",
              "    pm.expect(value).to.be.a(\"string\");\r",
              "    pm.expect(isNaN(Date.parse(value))).to.eql(false);\r",
              "  });\r",
              "});\r",
              "\r",
              "\r",
              "// =====================================================\r",
              "//   8. CLEANUP\r",
              "// =====================================================\r",
              "//\r",
              "// Postman variables persist across requests within a collection run.\r",
              "// Without cleanup, config set for request A leaks into request B —\r",
              "// causing false failures (fields asserted that don't exist) or\r",
              "// false passes (fields happen to exist but were never intended to be checked).\r",
              "//\r",
              "// Sentinel values:\r",
              "//   \"\"   → scalar — pm.variables.get() returns empty string, guards skip the block\r",
              "//   \"[]\" → array  — readJsonVariable() parses to [], forEach iterates zero times\r",
              "//   \"{}\" → object — readJsonVariable() parses to {}, Object.keys returns []\r",
              "\r",
              "clearValue(\"expectedStatus\",         \"\");\r",
              "clearValue(\"maxResponseTime\",        \"\");\r",
              "clearValue(\"expectedContentType\",    \"\");\r",
              "clearValue(\"expectedRootType\",       \"\");\r",
              "clearValue(\"requiredKeys\",           \"[]\");\r",
              "clearValue(\"enumRules\",              \"{}\");\r",
              "clearValue(\"nonEmptyStringFields\",   \"[]\");\r",
              "clearValue(\"positiveNumberFields\",   \"[]\");\r",
              "clearValue(\"booleanFields\",          \"[]\");\r",
              "clearValue(\"urlFields\",              \"[]\");\r",
              "clearValue(\"dateTimeFields\",         \"[]\");"
            ]
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "requests": {},
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "requests": {},
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "schemaErrorKey",
      "value": ""
    },
    {
      "key": "schema_store",
      "value": ""
    }
  ]
}