            {
              "name": "GET Character By ID",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "// =====================================================",
                      "// 📁 GET Character By ID — data-driven test",
                      "// =====================================================",
                      "//",
                      "// Validation rules branch on expected status — success and error responses",
                      "// have fundamentally different shapes and cannot share the same ruleset.",
                      "//",
                      "// Test data is driven by testData.json (one row per iteration):",
                      "//   { \"characterId\": 1,      \"characterExpectedStatus\": 200 }",
                      "//   { \"characterId\": 999999, \"characterExpectedStatus\": 404 }",
                      "",
                      "// Read expected status from iteration data.",
                      "// Falls back to 200 for manual single-request runs outside a collection run.",
                      "pm.variables.set(\"expectedStatus\", pm.iterationData.get(\"characterExpectedStatus\") || 200);",
                      "",
                      "// Tighter than the parent 1000ms default — consistent with folder-level threshold.",
                      "pm.variables.set(\"maxResponseTime\", 150);",
                      "",
                      "// Single character endpoint always returns one object, never an array.",
                      "pm.variables.set(\"expectedRootType\", \"object\");",
                      "",
                      "// Number() cast is required — pm.variables.get() always returns a string.",
                      "if (Number(pm.variables.get(\"expectedStatus\")) >= 400) {",
                      "",
                      "  // Error path — API returns { \"error\": \"Character not found\" }.",
                      "  // Character fields are absent, asserting them would always fail.",
                      "  pm.variables.set(\"requiredKeys\",         JSON.stringify([\"error\"]));",
                      "  pm.variables.set(\"enumRules\",            \"{}\");",
                      "  pm.variables.set(\"nonEmptyStringFields\", \"[]\");",
                      "  pm.variables.set(\"positiveNumberFields\", \"[]\");",
                      "  pm.variables.set(\"urlFields\",            \"[]\");",
                      "  pm.variables.set(\"dateTimeFields\",       \"[]\");",
                      "",
                      "} else {",
                      "",
                      "  // Success path — full character object contract validation.",
                      "  // All fields below are guaranteed present by the RickAndMorty API contract.",
                      "  pm.variables.set(\"requiredKeys\", JSON.stringify([",
                      "    \"id\", \"name\", \"status\", \"species\", \"gender\", \"image\", \"url\", \"created\"",
                      "  ]));",
                      "",
                      "  // status is a closed enum — any value outside this set indicates an API contract break.",
                      "  pm.variables.set(\"enumRules\", JSON.stringify({",
                      "    \"status\": [\"Alive\", \"Dead\", \"unknown\"]",
                      "  }));",
                      "",
                      "  // Fields that must be non-empty strings — empty value would indicate incomplete data.",
                      "  pm.variables.set(\"nonEmptyStringFields\", JSON.stringify([",
                      "    \"name\", \"species\", \"gender\", \"url\", \"created\"",
                      "  ]));",
                      "",
                      "  // id is always a positive integer — RickAndMorty IDs start at 1.",
                      "  pm.variables.set(\"positiveNumberFields\", JSON.stringify([\"id\"]));",
                      "",
                      "  // image and url must be reachable HTTP/HTTPS addresses.",
                      "  pm.variables.set(\"urlFields\", JSON.stringify([\"image\", \"url\"]));",
                      "",
                      "  // created is an ISO 8601 datetime string — validated via Date.parse().",
                      "  pm.variables.set(\"dateTimeFields\", JSON.stringify([\"created\"]));",
                      "}"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      ""
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{rickAndMortyBaseUrl}}character/{{characterId}}",
                  "host": [
                    "{{rickAndMortyBaseUrl}}character"
                  ],
                  "path": [
                    "{{characterId}}"
                  ]
                }
