              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "requests": {},
                "exec": [
                  "// =====================================================\r",
                  "// 📁 FOLDER DEFAULTS — REST Countries collections\r",
                  "// =====================================================\r",
                  "//\r",
                  "// Overrides top-level defaults for all REST Countries endpoints.\r",
                  "// Most values align with parent defaults — explicitly set here\r",
                  "// so this folder is self-documenting and not silently dependent\r",
                  "// on values set elsewhere.\r",
                  "\r",
                  "// Inherited from parent — restated explicitly for readability.\r",
                  "pm.variables.set(\"expectedStatus\",      \"200\");\r",
                  "pm.variables.set(\"expectedContentType\", \"application/json\");\r",
                  "\r",
                  "// REST Countries API is a public third-party service — 1000ms allows\r",
                  "// for occasional network variance without causing false failures.\r",
                  "pm.variables.set(\"maxResponseTime\", \"500\");\r",
                  "\r",
                  "// REST Countries returns a root-level array of country objects [ {...}, {...} ].\r",
                  "pm.variables.set(\"expectedRootType\", \"array\");\r",
                  "\r",
                  "// Both single-object and list endpoints share the same country shape —\r",
                  "// one schema covers both use cases.\r",
                  "pm.variables.set(\"schemaSingleKey\", \"country.schema\");\r",
                  "pm.variables.set(\"schemaListKey\",   \"country.schema\");\r",
                  "\r",
                  "// schemaErrorKey is defined in Collection Variables and inherited automatically —\r",
                  "// no override needed here."
