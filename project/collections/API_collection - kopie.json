                  "// GET Character By ID overrides these with full character field validation.",
                  "pm.variables.set(\"requiredKeys\",           JSON.stringify([\"info\", \"results\"]));",
                  "",
                  "// Individual character fields are not validated at list level —",
                  "// field-level assertions run only on single-object responses (GET by ID).",
                  "pm.variables.set(\"nonEmptyStringFields\",   JSON.stringify([]));",
                  "pm.variables.set(\"positiveNumberFields\",   JSON.stringify([]));",
                  "pm.variables.set(\"urlFields\",              JSON.stringify([]));",
                  "pm.variables.set(\"dateTimeFields\",         JSON.stringify([]));",
                  "pm.variables.set(\"enumRules\",              JSON.stringify({}));"
                ]
              }
            },
