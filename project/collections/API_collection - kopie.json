                      "// =====================================================",
                      "// 📁 GET Filter Characters",
                      "// =====================================================",
                      "//",
                      "// Minimal override — inherits all validation rules from the RickAndMorty",
                      "// folder defaults. Only request-specific values are set here.",
                      "",
                      "// Read filter name from iteration data (testData.json).",
                      "// Falls back to \"Morty\" for manual single-request runs outside a collection run.",
                      "// pm.iterationData.get() is required — pm.variables.get() cannot read data file values.",
                      "pm.variables.set(\"characterFilter\", pm.iterationData.get(\"characterFilter\") || \"Morty\");",
                      "",
                      "// Override folder default \"200\" — some iterations intentionally expect 404",
                      "// (e.g. searching for a character name that does not exist in the API).",
                      "pm.variables.set(\"expectedStatus\", pm.iterationData.get(\"filterExpectedStatus\") || \"200\");",
                      "",
                      "// For 404 responses the API returns { \"error\": \"...\" } instead of { info, results }.",
                      "// Override folder defaults to match the error response shape.",
                      "if (Number(pm.iterationData.get(\"filterExpectedStatus\")) >= 400) {",
                      "  pm.variables.set(\"expectedRootType\", \"object\");",
                      "  pm.variables.set(\"requiredKeys\",     JSON.stringify([\"error\"]));",
                      "}"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
